# Application runtime (non-superuser; PostgreSQL RLS is enforced)
DATABASE_URL=postgresql+psycopg://course_app:course@localhost:5432/course_service

# Migrations and role bootstrap only (database owner / superuser)
ADMIN_DATABASE_URL=postgresql+psycopg://course:course@localhost:5432/course_service

# Docker Compose sets both URLs for the api service automatically.
